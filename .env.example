# Copy to .env and adjust. Used by server/serve.cjs + server/api.cjs and the
# docker-compose stack. None are required for local-first use — the app works
# without a backend — but set them when hosting the API / cloud features.

# Server port (default 4173)
PORT=4173

# HMAC secret for signing & verifying Pro license keys (change in production!)
LICENSE_SECRET=change-me

# HMAC secret for account auth tokens (defaults to LICENSE_SECRET if unset)
AUTH_SECRET=change-me

# Enables POST /api/license/issue when set; sent as the x-admin-token header
ADMIN_TOKEN=

# When set, POST /api/checkout creates a real Stripe Checkout Session
STRIPE_SECRET_KEY=

# When set, POST /api/stripe/webhook verifies the Stripe-Signature header
STRIPE_WEBHOOK_SECRET=

# Where account + cloud data persist (defaults are inside server/)
USERS_FILE=./server/.users.json
BLOB_DIR=./server/.blobs

# Optional: surfaced by GET /api/version
GIT_COMMIT=
